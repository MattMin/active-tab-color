<idea-plugin>
    <id>com.matt.active-tab-color</id>
    <name>Active Tab Color</name>
    <vendor email="mzyupc@163.com" url="https://github.com/MattMin">MattMin</vendor>

    <description><![CDATA[
        Customize editor tab colors with active tab settings and regex-based tab name rules.
        Repository: <a href="https://github.com/MattMin/active-tab-color">https://github.com/MattMin/active-tab-color</a>
    ]]></description>

    <resource-bundle>messages.ActiveTabColorBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="com.matt.activetabcolor.settings"
                parentId="tools"
                instance="com.matt.activetabcolor.settings.ActiveTabColorConfigurable"
                bundle="messages.ActiveTabColorBundle"
                key="active.tab.color.settings.display.name"/>
        <editorTabColorProvider implementation="com.matt.activetabcolor.ui.ActiveTabColorProvider"/>
        <postStartupActivity implementation="com.matt.activetabcolor.ui.ActiveTabColorStartupActivity"/>
    </extensions>

    <projectListeners>
        <listener class="com.matt.activetabcolor.ui.ActiveTabColorFileEditorListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <action id="com.matt.activetabcolor.ToggleTabCat"
                class="com.matt.activetabcolor.ui.ToggleTabCatAction"
                text="Show Tab Cat"
                description="Show or hide the editor tab cat">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift C"/>
        </action>
    </actions>
</idea-plugin>
